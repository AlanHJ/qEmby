    font-size: 10px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

#playerSubtitleSettingsDialog QFrame#playerSubtitleSliderTile QWidget#SubtitleOptionSlider ModernSlider {
    qproperty-themeColor: #3B82F6;
    qproperty-trackColor: rgba(148, 163, 184, 0.32);
    qproperty-bufferColor: rgba(59, 130, 246, 0.16);
    qproperty-handleColor: #FFFFFF;
    qproperty-normalTrackHeight: 5;
    qproperty-hoverTrackHeight: 7;
