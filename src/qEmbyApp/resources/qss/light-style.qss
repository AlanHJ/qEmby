#playerDanmakuSettingsDialog QFrame#playerDanmakuSwitchTile,
#playerDanmakuSettingsDialog QFrame#playerDanmakuToggleTile,
#playerDanmakuSettingsDialog QFrame#playerDanmakuInputTile {
