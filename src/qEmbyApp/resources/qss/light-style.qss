    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

#playerDanmakuSettingsDialog QFrame#playerDanmakuSliderTile QWidget#DanmakuOptionSlider ModernSlider {
    qproperty-themeColor: #3B82F6;
    qproperty-trackColor: rgba(148, 163, 184, 0.32);
    qproperty-bufferColor: rgba(59, 130, 246, 0.16);
    qproperty-handleColor: #FFFFFF;
    qproperty-normalTrackHeight: 5;
    qproperty-hoverTrackHeight: 7;
    qproperty-normalHandleRadius: 6;
    qproperty-activeHandleRadius: 8;
}

#playerDanmakuSettingsDialog QFrame#playerDanmakuInputTile QFrame#TagInputContainer {
    background-color: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(148, 163, 184, 0.28);
    border-radius: 10px;
}

#playerDanmakuSettingsDialog QFrame#playerDanmakuInputTile QFrame#TagInputContainer:focus-within {
    border-color: rgba(59, 130, 246, 0.42);
}

ModernDialogBase#playerSubtitleSettingsDialog,
