#playerDanmakuSettingsDialog QFrame#playerDanmakuSummaryCard {
    background: rgba(255, 255, 255, 0.82);
    border: 1px solid rgba(59, 130, 246, 0.16);
    border-radius: 14px;
}

#playerDanmakuSettingsDialog QLabel#playerDanmakuSummaryText {
    font-size: 12px;
