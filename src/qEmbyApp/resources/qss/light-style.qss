    font-size: 11px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

#playerDanmakuSettingsDialog QFrame#playerDanmakuSliderTile QWidget#DanmakuOptionSlider {
    min-width: 0px;
    max-width: 16777215px;
}

#playerDanmakuSettingsDialog QFrame#playerDanmakuSliderTile QLabel#DanmakuOptionSliderValue,
#playerDanmakuSettingsDialog QFrame#playerDanmakuSliderTile QLineEdit#DanmakuOptionSliderValue,
#playerDanmakuSettingsDialog QFrame#playerDanmakuSliderTile QLineEdit#DanmakuOptionSliderValue:hover,
#playerDanmakuSettingsDialog QFrame#playerDanmakuSliderTile QLineEdit#DanmakuOptionSliderValue:focus {
