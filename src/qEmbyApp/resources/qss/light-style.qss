/* =========================================================
   全局基础设定 & Tailwind 色板变量映射 (供参考)
   Primary Blue: #3B82F6, Hover: #2563EB
   Danger Red:   #EF4444, Hover: #DC2626
   Gray-800 (标题): #1F2937
   Gray-600 (正文): #4B5563
   Gray-500 (弱化): #6B7280
   Gray-200 (边框): #E5E7EB
   Gray-50  (背景): #F9FAFB
========================================================= */

/* =========================================
   全局背景与滚动条
   ========================================= */

* {
    outline: none;
    /* 核心：一键消除所有控件的选中虚框 */
}

MainWindow {
    background-color: #F1F5F9;
}

MainWindow[custom-style=true] {
    background-color: transparent;
}

QScrollBar:vertical {
    border: none;
    background: transparent;
    width: 10px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: rgba(15, 23, 42, 0.15);
    min-height: 30px;
    margin: 0px 3px;
    border-radius: 2px;
}

QScrollBar::handle:vertical:hover,
QScrollBar::handle:vertical:pressed {
    background: rgba(15, 23, 42, 0.35);
    margin: 0px 1px;
    border-radius: 4px;
}

QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical,
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    border: none;
    background: none;
    height: 0px;
}

/* =========================================
   Window Bar (无边框窗口系统控制 - 主窗口)
   ========================================= */
QWK--WindowBar[bar-active=true],
QWK--WindowBar[bar-active=false] {
    background-color: transparent;
}

QWK--WindowBar>QLabel#win-title-label {
    padding: 0;
    border: none;
    color: #1F2937;
    background-color: transparent;
    min-height: 32px;
    font-size: 14px;
    font-weight: 600;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

/* =========================================
   搜索框组件：全新现代胶囊风格与微交互
   ========================================= */
/* 标题栏居中全局搜索框 */
QLineEdit#titlebar-search {
    background-color: #F3F4F6;
    border: 1px solid transparent;
    border-radius: 16px;
    /* 32px 高度对应的完美胶囊圆角 */
    padding: 0px 18px 0px 8px;
    /* 右侧留白防止文字遮挡清空按钮 */
    font-size: 13px;
    font-weight: 500;
    color: #1F2937;
    margin: 0;
}

QLineEdit#titlebar-search:hover {
    background-color: #E5E7EB;
    /* 悬浮微量加深 */
}

QLineEdit#titlebar-search:focus {
    background-color: #FFFFFF;
    /* 焦点状态纯白底色，吸引注意力 */
    border: 1px solid #3B82F6;
    /* 主题蓝边框高亮 */
}

/* 侧边栏内部搜索框 */
QLineEdit#sidebar-search {
    background-color: #F3F4F6;
    border: 1px solid transparent;
    border-radius: 8px;
    /* 圆角配合现代卡片风格 */
    padding: 6px 10px;
    font-size: 13px;
    font-weight: 500;
    color: #1F2937;
    min-height: 20px;
}

QLineEdit#sidebar-search:hover {
    background-color: #E5E7EB;
}

QLineEdit#sidebar-search:focus {
    background-color: #FFFFFF;
    border: 1px solid #3B82F6;
}

QFrame#SearchHistoryPopup {
    background: transparent;
    border: none;
}

QFrame#SearchHistoryPopupCard {
    background-color: #FFFFFF;
    border: 1px solid #E4EBF3;
    border-radius: 14px;
}

QWidget#SearchHistoryPopupHeader {
    background: transparent;
    border: none;
    min-height: 16px;
}

QFrame#SearchHistoryHeaderDivider {
    background-color: #E7EDF5;
    border: none;
}

QWidget#SearchHistoryPopupBody,
QScrollArea#SearchHistoryScrollArea,
QWidget#SearchHistoryFlowHost,
QWidget#SearchHistoryScrollViewport {
    background: transparent;
    border: none;
}

QScrollArea#SearchHistoryScrollArea QScrollBar:vertical {
    background: transparent;
    width: 4px;
    margin: 12px 0px 12px 0px;
}

QScrollArea#SearchHistoryScrollArea QScrollBar::handle:vertical {
    background-color: #D1DDED;
    border: none;
    border-radius: 2px;
    min-height: 28px;
}

QScrollArea#SearchHistoryScrollArea QScrollBar::handle:vertical:hover {
    background-color: #BDD0E8;
}

QScrollArea#SearchHistoryScrollArea QScrollBar::add-line:vertical,
QScrollArea#SearchHistoryScrollArea QScrollBar::sub-line:vertical,
QScrollArea#SearchHistoryScrollArea QScrollBar::add-page:vertical,
QScrollArea#SearchHistoryScrollArea QScrollBar::sub-page:vertical {
    background: transparent;
    border: none;
    height: 0px;
}

QToolButton#SearchHistoryModeButton,
QToolButton#SearchHistoryClearButton,
QToolButton#SearchHistoryExpandButton {
    background-color: transparent;
    border: none;
    border-radius: 8px;
    padding: 0px;
    min-width: 16px;
    min-height: 16px;
}

QToolButton#SearchHistoryModeButton:hover,
QToolButton#SearchHistoryClearButton:hover,
QToolButton#SearchHistoryExpandButton:hover {
    background-color: #F7FAFD;
}

QToolButton#SearchHistoryModeButton:checked,
QToolButton#SearchHistoryExpandButton:checked {
    background-color: #EEF4FF;
}

QToolButton#SearchHistoryModeButton:checked:hover,
QToolButton#SearchHistoryExpandButton:checked:hover {
    background-color: #E9F0FF;
}

QToolButton#SearchHistoryClearButton[armed="true"] {
    background-color: #FDEEEE;
}

QToolButton#SearchHistoryClearButton[armed="true"]:hover {
    background-color: #FCE4E4;
}

QAbstractButton#SearchHistoryChip {
    background: transparent;
    border: none;
    padding: 0px;
}

QListView#SearchCompleterPopup,
QListView#SearchHistoryCompleterPopup {
    background-color: #FFFFFF;
    border: 1px solid #E4EBF3;
    border-radius: 20px;
    padding: 0px;
    outline: none;
}

QListView#SearchCompleterPopup::item,
QListView#SearchHistoryCompleterPopup::item {
    padding: 0px;
    margin: 0px;
    border: none;
    background: transparent;
    color: #334155;
}

QListView#SearchCompleterPopup::item:hover,
QListView#SearchCompleterPopup::item:selected,
QListView#SearchHistoryCompleterPopup::item:hover,
QListView#SearchHistoryCompleterPopup::item:selected {
    background: transparent;
    border: none;
}

QListView#SearchCompleterPopup QScrollBar:vertical,
QListView#SearchHistoryCompleterPopup QScrollBar:vertical {
    background: transparent;
    width: 8px;
    margin: 8px 4px 8px 0px;
}

QListView#SearchCompleterPopup QScrollBar::handle:vertical,
QListView#SearchHistoryCompleterPopup QScrollBar::handle:vertical {
    background-color: #D9E6F6;
    border: none;
    border-radius: 4px;
    min-height: 34px;
}

QListView#SearchCompleterPopup QScrollBar::handle:vertical:hover,
QListView#SearchHistoryCompleterPopup QScrollBar::handle:vertical:hover {
    background-color: #C7DBF7;
}

QListView#SearchCompleterPopup QScrollBar::add-line:vertical,
QListView#SearchCompleterPopup QScrollBar::sub-line:vertical,
QListView#SearchCompleterPopup QScrollBar::add-page:vertical,
QListView#SearchCompleterPopup QScrollBar::sub-page:vertical,
QListView#SearchHistoryCompleterPopup QScrollBar::add-line:vertical,
QListView#SearchHistoryCompleterPopup QScrollBar::sub-line:vertical,
QListView#SearchHistoryCompleterPopup QScrollBar::add-page:vertical,
QListView#SearchHistoryCompleterPopup QScrollBar::sub-page:vertical {
    background: transparent;
    border: none;
    height: 0px;
}


QWK--WindowBar>QAbstractButton[system-button=true] {
    qproperty-iconSize: 12px 12px;
    min-width: 50px;
    border: none;
    border-radius: 0px;
    padding: 0;
    background-color: transparent;
}

QWK--WindowBar>QAbstractButton#pin-button {
    qproperty-iconNormal: url(":/svg/light/pin.svg");
    qproperty-iconChecked: url(":/svg/light/pin-fill.svg");
    qproperty-iconSize: 15px 15px;
}

QWK--WindowBar>QAbstractButton#back-button:hover,
QWK--WindowBar>QAbstractButton#home-button:hover,
QWK--WindowBar>QAbstractButton#fav-button:hover,
QWK--WindowBar>QAbstractButton#pin-button:hover,
QWK--WindowBar>QAbstractButton#pin-button:pressed,
QWK--WindowBar>QAbstractButton#theme-button:hover,
QWK--WindowBar>QAbstractButton#theme-button:pressed,
QWK--WindowBar>QAbstractButton#min-button:hover,
QWK--WindowBar>QAbstractButton#min-button:pressed,
QWK--WindowBar>QAbstractButton#max-button:hover,
QWK--WindowBar>QAbstractButton#max-button:pressed {
    background-color: rgba(0, 0, 0, 8%);
}

QWK--WindowBar>QAbstractButton#fav-button {
    margin-right: 10px;
}


QWK--WindowBar>QAbstractButton#back-button:pressed,
QWK--WindowBar>QAbstractButton#home-button:pressed,
QWK--WindowBar>QAbstractButton#fav-button:pressed {
    background-color: rgba(0, 0, 0, 18%);
}

QWK--WindowBar>QAbstractButton#min-button {
    qproperty-iconNormal: url(":/svg/light/minimize.svg");
}

QWK--WindowBar>QAbstractButton#back-button {
    qproperty-iconNormal: url(":/svg/light/arrow-left.svg");
}

QWK--WindowBar>QAbstractButton#home-button {
    qproperty-iconNormal: url(":/svg/light/bar-home.svg");
}

QWK--WindowBar>QAbstractButton#fav-button {
    qproperty-iconNormal: url(":/svg/light/bar-heart.svg");
}



QWK--WindowBar>QAbstractButton#max-button {
    qproperty-iconNormal: url(":/svg/light/maximize.svg");
    qproperty-iconChecked: url(":/svg/light/restore.svg");
}

QWK--WindowBar>QAbstractButton#close-button {
    qproperty-iconNormal: url(":/svg/light/close.svg");
}

QWK--WindowBar>QAbstractButton#close-button:hover,
QWK--WindowBar>QAbstractButton#close-button:pressed {
    background-color: #E81123;
    qproperty-iconNormal: url(":/svg/close.svg");
}

QWK--WindowBar>QAbstractButton#icon-button {
    qproperty-iconNormal: url(":/svg/qemby_logo.svg");
    qproperty-iconSize: 18px 18px;
    min-width: 40px;
    border: none;
    padding: 0;
    background-color: transparent;
}

/* =========================================
   Menu Bar & Menu
   ========================================= */
QMenuBar {
    background-color: transparent;
    border: none;
}

QMenuBar>QToolButton#qt_menubar_ext_button {
    qproperty-icon: url(":/svg/light/more-line.svg");
}

QMenuBar>QToolButton#qt_menubar_ext_button:hover,
QMenuBar>QToolButton#qt_menubar_ext_button:pressed,
QMenuBar::item:selected {
    background-color: #E5E7EB;
    border-radius: 4px;
}

QMenuBar::item {
    color: #4B5563;
    border: none;
    padding: 6px 12px;
    margin: 2px;
}

QMenu {
    padding: 6px;
    background: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 8px;
}

QMenu::item {
    background: transparent;
    color: #4B5563;
    padding: 8px 24px 8px 12px;
    border-radius: 4px;
    margin: 2px 0px;
}

QMenu::item:selected {
    background-color: #F3F4F6;
    color: #1F2937;
}

QMenu::item:disabled {
    color: #9CA3AF;
}

QMenu::separator {
    height: 1px;
    background-color: #E5E7EB;
    margin: 6px 0;
}

QMenu#AppTextContextMenu {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
    padding: 8px 0px;
}

QMenu#AppTextContextMenu::item {
    margin: 0px 8px;
    padding: 10px 20px 10px 10px;
    border-radius: 8px;
    color: #1E293B;
    font-size: 13px;
    font-weight: 500;
    background-color: transparent;
}

QMenu#AppTextContextMenu::item:selected {
    background-color: #F1F5F9;
    color: #0F172A;
}

QMenu#AppTextContextMenu::item:disabled {
    color: #94A3B8;
}

QMenu#AppTextContextMenu::separator {
    height: 1px;
    background-color: #E2E8F0;
    margin: 6px 14px;
}

QMenu#AppTextContextMenu::icon {
    padding-right: 12px;
}

/* =========================================
   现代 Tailwind 蓝白风格 - 登录页及公共组件
   ========================================= */

QLabel#login-title {
    font-size: 20px;
    font-weight: 700;
    color: #1F2937;
    margin-bottom: 5px;
}

QWidget#login-add-page {
    background: transparent;
    border: none;
}

QWidget#login-add-page QLabel#login-error-label {
    color: #EF4444;
    font-size: 13px;
    font-weight: bold;
    background: transparent;
}

QWidget#login-add-page QLineEdit {
    background-color: #FFFFFF;
    border: 1px solid #CBD5E1;
    border-radius: 8px;
    color: #1E293B;
    font-size: 13px;
    font-weight: 500;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 5px 12px;
    min-height: 24px;
    selection-background-color: rgba(59, 130, 246, 0.10);
    selection-color: #2563EB;
    placeholder-text-color: #94A3B8;
}

QWidget#login-add-page QLineEdit:hover {
    background-color: #F8FAFC;
    border-color: #94A3B8;
}

QWidget#login-add-page QLineEdit:focus {
    border-color: #3B82F6;
    background-color: #EFF6FF;
}

QWidget#login-add-page QWidget#login-ssl-card {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 12px;
}

QWidget#login-add-page QWidget#login-ssl-card:hover {
    background-color: #F8FAFC;
    border-color: #CBD5E1;
}

QWidget#login-add-page QLabel#login-ssl-title {
    color: #1E293B;
    font-size: 13px;
    font-weight: 400;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    background-color: transparent;
}

QWidget#login-add-page QLabel#login-ssl-description {
    color: #94A3B8;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    background-color: transparent;
}

QWidget#server-card {
    background-color: #FFFFFF;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
}

QWidget#server-card:hover {
    background-color: #F9FAFB;
    border: 1px solid #D1D5DB;
}

QLabel#server-name-label {
    font-weight: 700;
    color: #1F2937;
}

QLabel#server-url-label {
    color: #6B7280;
}

QLabel#server-fallback-icon {
    background-color: #EFF6FF;
    color: #3B82F6;
    border-radius: 20px;
    font-weight: bold;
}

QPushButton#action-edit-btn {
    qproperty-icon: url(":/svg/light/edit.svg");
    qproperty-iconSize: 16px 16px;
    background-color: #6B7280;
    border: none;
    border-radius: 6px;
    padding: 6px;
}

QPushButton#action-edit-btn:hover {
    background-color: #4B5563;
}

QPushButton#action-del-btn {
    qproperty-icon: url(":/svg/light/delete.svg");
    qproperty-iconSize: 16px 16px;
    background-color: #EF4444;
    border: none;
    border-radius: 6px;
    padding: 6px;
}

QPushButton#action-del-btn:hover {
    background-color: #DC2626;
}

QPushButton#add-server-btn {
    qproperty-icon: url(":/svg/light/add.svg");
    qproperty-iconSize: 16px 16px;
    background-color: transparent;
    border: 2px dashed #BFDBFE;
    border-radius: 12px;
    color: #3B82F6;
    font-size: 14px;
    font-weight: 600;
    padding: 12px;
    text-align: center;
}

QPushButton#add-server-btn:hover {
    background-color: #EFF6FF;
    border-color: #93C5FD;
}

QLineEdit,
QComboBox {
    background-color: #FFFFFF;
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    padding: 8px 12px;
    font-size: 14px;
    color: #1F2937;
    min-height: 22px;
    selection-background-color: #93C5FD;
    selection-color: #0F172A;
}

QComboBox {
    padding-right: 26px;
}

QLineEdit:focus,
QComboBox:focus {
    border: 2px solid #3B82F6;
    padding: 7px 11px;
}

QComboBox:focus {
    padding-right: 25px;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 28px;
    border-left: 1px solid #E5E7EB;
    border-top-right-radius: 6px;
    border-bottom-right-radius: 6px;
    background-color: transparent;
}

QComboBox::down-arrow {
    image: url(":/svg/light/chevron-down.svg");
    width: 14px;
    height: 14px;
}

QComboBox QAbstractItemView {
    border: 1px solid #D1D5DB;
    border-radius: 8px;
    background-color: #FFFFFF;
    selection-background-color: #EFF6FF;
    selection-color: #1D4ED8;
    outline: none;
    padding: 4px;
}

QComboBox QAbstractItemView::item {
    min-height: 28px;
    padding-left: 8px;
    color: #4B5563;
    border-radius: 4px;
    border: none;
}

QComboBox QAbstractItemView::item:hover,
QComboBox QAbstractItemView::item:selected {
    background-color: #EFF6FF;
    color: #1D4ED8;
    border: none;
}

QWidget#login-add-page ModernComboBox#login-protocol-combo {
    background-color: #FFFFFF;
    border: 1px solid #CBD5E1;
    border-radius: 8px;
    color: #1E293B;
    font-size: 13px;
    font-weight: 500;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 5px 32px 5px 16px;
    min-height: 24px;
    selection-background-color: transparent;
}

QWidget#login-add-page ModernComboBox#login-protocol-combo:hover {
    background-color: #F8FAFC;
    border-color: #94A3B8;
}

QWidget#login-add-page ModernComboBox#login-protocol-combo:focus {
    background-color: #EFF6FF;
    border-color: #3B82F6;
    outline: none;
}

QWidget#login-add-page ModernComboBox#login-protocol-combo::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: center right;
    width: 32px;
    border: none;
    background: transparent;
}

QWidget#login-add-page ModernComboBox#login-protocol-combo::down-arrow {
    image: url(":/svg/light/chevron-down.svg");
    width: 14px;
    height: 14px;
}

QWidget#login-add-page ModernComboBox#login-protocol-combo QAbstractItemView {
    background-color: #FFFFFF;
    border: 1px solid #E2E8F0;
    border-radius: 8px;
    color: #1E293B;
    font-size: 13px;
    outline: none;
    selection-background-color: rgba(59, 130, 246, 0.10);
    selection-color: #2563EB;
    padding: 4px;
}

QWidget#login-add-page ModernComboBox#login-protocol-combo QAbstractItemView::item {
    padding: 5px 12px;
    border-radius: 6px;
    color: #334155;
}

QWidget#login-add-page ModernComboBox#login-protocol-combo QAbstractItemView::item:hover {
    background-color: #F1F5F9;
    color: #0F172A;
}

QWidget#login-add-page ModernComboBox#login-protocol-combo QAbstractItemView::item:selected,
QWidget#login-add-page ModernComboBox#login-protocol-combo QAbstractItemView::item:selected:hover {
    background-color: rgba(59, 130, 246, 0.10);
    color: #2563EB;
}

QLabel#url-colon {
    font-size: 18px;
    font-weight: bold;
    color: #6B7280;
}

QPushButton {
    background-color: #FFFFFF;
    color: #4B5563;
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    padding: 10px 16px;
    font-size: 14px;
    font-weight: 500;
}

QPushButton:hover {
    background-color: #F9FAFB;
    color: #1F2937;
    border-color: #9CA3AF;
}

QWidget#login-add-page QPushButton {
    background-color: #FFFFFF;
    color: #1E293B;
    border: 1px solid #CBD5E1;
    border-radius: 8px;
    padding: 5px 16px;
    font-size: 13px;
    font-weight: 500;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    min-height: 24px;
}

QWidget#login-add-page QPushButton:hover {
    background-color: #F8FAFC;
    color: #0F172A;
    border-color: #94A3B8;
}

QWidget#login-add-page QPushButton:pressed {
    background-color: #F1F5F9;
    color: #334155;
}

QWidget#login-add-page ModernSwitch {
    qproperty-trackColorActive: #3B82F6;
    qproperty-trackColorInactive: #CBD5E1;
    qproperty-thumbColor: #FFFFFF;
}

QWidget#login-add-page QPushButton#login-button {
    background-color: #3B82F6;
    border: 1px solid rgba(59, 130, 246, 0.22);
    color: #FFFFFF;
    font-weight: 600;
}

QWidget#login-add-page QPushButton#login-button:hover {
    background-color: #2563EB;
    border-color: rgba(37, 99, 235, 0.28);
}

QWidget#login-add-page QPushButton#login-button:disabled {
    background-color: #93C5FD;
    color: #EFF6FF;
    border-color: transparent;
}

QPushButton#password-toggle-btn {
    background-color: transparent;
    border: 1px solid transparent;
    border-radius: 6px;
    padding: 4px;
}

QPushButton#password-toggle-btn:hover {
    background-color: #F3F4F6;
    border: 1px solid #E5E7EB;
}

QLabel#app-version-label {
    font-size: 11px;
    font-weight: 500;
    color: #9CA3AF;
    letter-spacing: 0.5px;
}

/* =========================================
   自定义现代化弹窗 (QWK ModernDialogBase)
   ========================================= */

/* 给原生的 QDialog 直接赋予白底，完美结合 QWK 原生硬件阴影 */
ModernDialogBase,
ModernMessageBox {
    background-color: #FFFFFF;
    border: 1px solid #D1D5DB;
    /* 如果开启了 Win11 原生圆角，边框将被裁剪，对低版本系统起到兜底作用 */
}

QWidget[playerDialogSurface="true"] {
    background-color: rgba(255, 255, 255, 0.96);
    border: 1px solid #D1D5DB;
    border-radius: 18px;
}

QWidget#dialog-titlebar {
    background-color: transparent;
    min-height: 34px;
}

QLabel#dialog-title {
    font-size: 14px;
    font-weight: 700;
    color: #1F2937;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

/* 弹窗专用关闭按钮：完美贴合右上角，悬停变红底白叉 */
QWK--WindowButton#dialog-close-btn,
QPushButton#dialog-close-btn {
    qproperty-iconNormal: url(":/svg/light/close.svg");
    qproperty-iconSize: 12px 12px;
    background-color: transparent;
    border: none;
    border-radius: 0px;
    /* 方形贴边 */
    min-width: 46px;
    /* Win11 原生按钮宽度 */
    min-height: 34px;
    padding: 0;
}

QWK--WindowButton#dialog-close-btn:hover,
QPushButton#dialog-close-btn:hover {
    background-color: #E81123;
    qproperty-iconNormal: url(":/svg/close.svg");
    /* 悬停切换为纯白 SVG */
}

QWK--WindowButton#dialog-close-btn:pressed,
QPushButton#dialog-close-btn:pressed {
    background-color: #F1707A;
}

/* PlayerOverlayDialog 内置对话框关闭按钮：右上角圆角匹配 surface 圆角 */
QWidget[playerDialogSurface="true"] QPushButton#dialog-close-btn {
    border-top-right-radius: 17px;
}

QWidget[playerDialogSurface="true"] QPushButton#dialog-close-btn:hover {
    border-top-right-radius: 17px;
}

QLabel#dialog-text {
    font-size: 14px;
    color: #4B5563;
    line-height: 1.5;
    padding-top: 4px;
}

QWidget#dialog-option-row {
    background: transparent;
    border: none;
}

QLabel#dialog-option-label {
    color: #334155;
    font-size: 13px;
    font-weight: 600;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

/* 弹窗取消按钮 (与 SettingsCardButton 形状一致) */
QPushButton#dialog-btn-cancel {
    background-color: #FFFFFF;
    border: 1px solid #CBD5E1;
    border-radius: 8px;
    color: #1E293B;
    font-size: 13px;
    font-weight: 500;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 5px 16px;
    min-width: 80px;
}

QPushButton#dialog-btn-cancel:hover {
    background-color: #F8FAFC;
    border-color: #94A3B8;
    color: #0F172A;
}

QPushButton#dialog-btn-cancel:pressed {
    background-color: #F1F5F9;
    color: #334155;
}

/* 弹窗危险按钮 (红) */
QPushButton#dialog-btn-danger {
    background-color: #EF4444;
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    padding: 5px 16px;
    font-size: 13px;
    font-weight: 600;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    min-width: 80px;
}

QPushButton#dialog-btn-danger:hover {
    background-color: #DC2626;
}

/* 弹窗确认按钮 (蓝) */
QPushButton#dialog-btn-primary {
    background-color: #3B82F6;
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    padding: 5px 16px;
    font-size: 13px;
    font-weight: 600;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    min-width: 80px;
}

QPushButton#dialog-btn-primary:hover {
    background-color: #2563EB;
}

QPushButton#dialog-btn-primary:disabled {
    background-color: rgba(59, 130, 246, 0.4);
    color: rgba(255, 255, 255, 0.7);
}

ModernDialogBase#playerDanmakuSettingsDialog,
QDialog#playerDanmakuSettingsDialog,
QWidget#playerDanmakuSettingsDialog {
    background-color: rgba(248, 250, 252, 0.92);
    border: 1px solid rgba(203, 213, 225, 0.90);
