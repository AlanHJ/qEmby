   媒体库管理 (PageLibraries) - 暗黑模式
   ===================================================================== */

/* 库列表容器 */
QListWidget#ManageLibraryList {
    background: transparent;
    border: none;
    outline: none;
}

QListWidget#ManageLibraryList::item {
    background: transparent;
    border: none;
    padding: 0;
}

/* 库卡片 Delegate 主题色 */
#library-card-theme {
    qproperty-cardBg: rgba(51, 65, 85, 102);
    qproperty-borderColor: rgba(71, 85, 105, 77);
    qproperty-nameColor: #F1F5F9;
    qproperty-typeColor: #94A3B8;
    qproperty-pathColor: #64748B;
    qproperty-handleColor: rgba(148, 163, 184, 0.5);
}

/* 扫描全部按钮 */
QPushButton#ManageLibScanAllBtn {
    background-color: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
    qproperty-icon: url(":/svg/dark/scan-library.svg");
    qproperty-iconSize: 16px 16px;
}

QPushButton#ManageLibScanAllBtn:hover {
    background-color: rgba(34, 197, 94, 0.25);
    border-color: rgba(34, 197, 94, 0.5);
}

QPushButton#ManageLibScanAllBtn:pressed {
    background-color: rgba(34, 197, 94, 0.35);
}

/* 创建新库按钮 */
QPushButton#ManageLibCreateBtn {
    background-color: rgba(59, 130, 246, 0.15);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 8px;
    qproperty-icon: url(":/svg/dark/add.svg");
    qproperty-iconSize: 16px 16px;
}

QPushButton#ManageLibCreateBtn:hover {
    background-color: rgba(59, 130, 246, 0.25);
    border-color: rgba(59, 130, 246, 0.5);
}

QPushButton#ManageLibCreateBtn:pressed {
    background-color: rgba(59, 130, 246, 0.35);
}

/* 列表页全选按钮 */
QPushButton#ManageListSelectBtn {
    background-color: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
    qproperty-icon: url(":/svg/dark/check.svg");
    qproperty-iconSize: 16px 16px;
}

QPushButton#ManageListSelectBtn:hover {
    background-color: rgba(34, 197, 94, 0.25);
    border-color: rgba(34, 197, 94, 0.5);
}

QPushButton#ManageListSelectBtn:pressed {
    background-color: rgba(34, 197, 94, 0.35);
}

QPushButton#ManageListSelectBtn:disabled {
    background-color: rgba(34, 197, 94, 0.08);
    border-color: rgba(34, 197, 94, 0.15);
}

/* 列表页批量删除按钮 */
QPushButton#ManageListDeleteBtn {
    background-color: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 8px;
    qproperty-icon: url(":/svg/dark/delete.svg");
    qproperty-iconSize: 16px 16px;
}

QPushButton#ManageListDeleteBtn:hover {
    background-color: rgba(239, 68, 68, 0.25);
    border-color: rgba(239, 68, 68, 0.5);
}

QPushButton#ManageListDeleteBtn:pressed {
    background-color: rgba(239, 68, 68, 0.35);
}

QPushButton#ManageListDeleteBtn:disabled {
    background-color: rgba(239, 68, 68, 0.08);
    border-color: rgba(239, 68, 68, 0.15);
}

/* ── 媒体库卡片操作按钮 ── */
QPushButton#LibCardEditBtn,
QPushButton#LibCardScanBtn,
QPushButton#LibCardDeleteBtn {
    background: transparent;
    border: none;
    border-radius: 6px;
    qproperty-iconSize: 14px 14px;
}

QPushButton#LibCardEditBtn {
    qproperty-icon: url(":/svg/dark/edit.svg");
}
QPushButton#LibCardEditBtn:hover {
    background-color: rgba(59, 130, 246, 0.25);
}
QPushButton#LibCardEditBtn:pressed {
    background-color: rgba(59, 130, 246, 0.4);
}

QPushButton#LibCardScanBtn {
    qproperty-icon: url(":/svg/dark/scan-library.svg");
}
QPushButton#LibCardScanBtn:hover {
    background-color: rgba(34, 197, 94, 0.25);
}
QPushButton#LibCardScanBtn:pressed {
    background-color: rgba(34, 197, 94, 0.4);
}

QPushButton#LibCardDeleteBtn {
    qproperty-icon: url(":/svg/dark/delete.svg");
}
QPushButton#LibCardDeleteBtn:hover {
    background-color: rgba(239, 68, 68, 0.25);
}
QPushButton#LibCardDeleteBtn:pressed {
    background-color: rgba(239, 68, 68, 0.4);
}

/* 添加路径按钮 */
QPushButton#ManageLibAddPathBtn {
    background-color: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 6px;
    color: #94A3B8;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 4px 12px;
}

QPushButton#ManageLibAddPathBtn:hover {
    background-color: rgba(255, 255, 255, 0.12);
    color: #E2E8F0;
}

/* 删除路径按钮 */
QPushButton#ManageLibRemovePathBtn {
    background-color: rgba(239, 68, 68, 0.10);
    border: 1px solid rgba(239, 68, 68, 0.20);
    border-radius: 6px;
    color: #FCA5A5;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 4px 12px;
}

QPushButton#ManageLibRemovePathBtn:hover {
    background-color: rgba(239, 68, 68, 0.20);
    color: #FCA5A5;
}

/* 对话框内输入框 */
QLineEdit#ManageLibInput {
    background-color: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 8px;
    color: #E2E8F0;
    font-size: 13px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 6px 10px;
}

QLineEdit#ManageLibInput:focus {
    border-color: rgba(59, 130, 246, 0.5);
}

/* 路径列表 */
QListWidget#ManageLibPathList {
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    color: #CBD5E1;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 4px;
    outline: none;
}

QListWidget#ManageLibPathList::item {
    padding: 4px 8px;
    border-radius: 4px;
}

QListWidget#ManageLibPathList::item:selected {
    background-color: rgba(59, 130, 246, 0.20);
    color: #93C5FD;
}

QListWidget#ManageLibPathList::item:hover {
    background-color: rgba(255, 255, 255, 0.06);
}

/* ── 高级设置折叠按钮 ── */
QPushButton#LibAdvancedToggle {
    background: transparent;
    border: none;
    color: #94A3B8;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    text-align: left;
    padding: 4px 0;
}

QPushButton#LibAdvancedToggle:hover {
    color: #CBD5E1;
}

/* ── 高级设置面板 ── */
QWidget#LibAdvancedPanel {
    background-color: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
}

/* ── 高级设置复选框 ── */
QCheckBox#ManageLibCheckBox {
    color: #CBD5E1;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    spacing: 8px;
}

QCheckBox#ManageLibCheckBox::indicator {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    background-color: rgba(255, 255, 255, 0.05);
}

QCheckBox#ManageLibCheckBox::indicator:checked {
    background-color: rgba(59, 130, 246, 0.6);
    border-color: rgba(59, 130, 246, 0.8);
    image: url(:/svg/dark/check.svg);
}

/* ── 可排序抽取器行 — 箭头按钮 ── */
QPushButton#FetcherArrowBtn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 4px;
    color: #94A3B8;
    font-size: 9px;
    padding: 0;
}

QPushButton#FetcherArrowBtn:hover {
    background-color: rgba(255, 255, 255, 0.08);
    color: #E2E8F0;
}

QPushButton#FetcherArrowBtn:pressed {
    background-color: rgba(255, 255, 255, 0.14);
}

QPushButton#FetcherArrowBtn:disabled {
    color: rgba(148, 163, 184, 0.25);
    border-color: transparent;
}

/* ── 可排序抽取器行 — 名称标签 ── */
QLabel#FetcherRowLabel {
    color: #CBD5E1;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding-left: 4px;
}

/* ── 可排序抽取器行 — 行容器 ── */
QWidget#FetcherRowWidget {
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 6px;
}

/* ── 高级设置 SpinBox ── */
QSpinBox#ManageLibSpinBox,
QDoubleSpinBox#ManageLibSpinBox {
    background-color: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 6px;
    color: #E2E8F0;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 3px 24px 3px 8px;
    min-width: 80px;
    selection-background-color: rgba(59, 130, 246, 0.5);
    selection-color: #FFFFFF;
}

QSpinBox#ManageLibSpinBox:focus,
QDoubleSpinBox#ManageLibSpinBox:focus {
    border-color: rgba(59, 130, 246, 0.5);
}

QSpinBox#ManageLibSpinBox::up-button,
QDoubleSpinBox#ManageLibSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.10);
    border-right: 1px solid rgba(255, 255, 255, 0.10);
    border-bottom: none;
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    border-top-right-radius: 5px;
    background: rgba(255, 255, 255, 0.04);
}

QSpinBox#ManageLibSpinBox::up-button:hover,
QDoubleSpinBox#ManageLibSpinBox::up-button:hover {
    background: rgba(255, 255, 255, 0.10);
}

QSpinBox#ManageLibSpinBox::up-button:pressed,
QDoubleSpinBox#ManageLibSpinBox::up-button:pressed {
    background: rgba(59, 130, 246, 0.25);
}

QSpinBox#ManageLibSpinBox::up-arrow,
QDoubleSpinBox#ManageLibSpinBox::up-arrow {
    image: url(:/svg/dark/spinbox-up.svg);
    width: 8px;
    height: 5px;
}

QSpinBox#ManageLibSpinBox::down-button,
QDoubleSpinBox#ManageLibSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-right: 1px solid rgba(255, 255, 255, 0.10);
    border-bottom: 1px solid rgba(255, 255, 255, 0.10);
    border-left: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom-right-radius: 5px;
    background: rgba(255, 255, 255, 0.04);
}

QSpinBox#ManageLibSpinBox::down-button:hover,
QDoubleSpinBox#ManageLibSpinBox::down-button:hover {
    background: rgba(255, 255, 255, 0.10);
}

QSpinBox#ManageLibSpinBox::down-button:pressed,
QDoubleSpinBox#ManageLibSpinBox::down-button:pressed {
    background: rgba(59, 130, 246, 0.25);
}

QSpinBox#ManageLibSpinBox::down-arrow,
QDoubleSpinBox#ManageLibSpinBox::down-arrow {
    image: url(:/svg/dark/spinbox-down.svg);
    width: 8px;
    height: 5px;
}

/* ── 高级设置分隔线 ── */
QFrame#ManageLibSeparator {
    background-color: rgba(255, 255, 255, 0.08);
    max-height: 1px;
    border: none;
}

/* ── 创建对话框滚动区 ── */
QScrollArea#LibCreateScrollArea {
    background: transparent;
}
QScrollArea#LibCreateScrollArea > QWidget > QWidget {
    background: transparent;
}

/* ── 对话框内 ComboBox ── */
QComboBox#ManageLibComboBox {
    background-color: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 8px;
    color: #E2E8F0;
    font-size: 13px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 6px 10px;
    min-height: 20px;
}

QComboBox#ManageLibComboBox:hover {
    border-color: rgba(255, 255, 255, 0.18);
}

QComboBox#ManageLibComboBox:focus {
    border-color: rgba(59, 130, 246, 0.5);
}

QComboBox#ManageLibComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 28px;
    border: none;
}

QComboBox#ManageLibComboBox::down-arrow {
    image: url(:/svg/dark/chevron-down.svg);
    width: 12px;
    height: 12px;
}

QComboBox#ManageLibComboBox QAbstractItemView {
    background-color: #1E293B;
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 8px;
    color: #CBD5E1;
    selection-background-color: rgba(59, 130, 246, 0.20);
    selection-color: #93C5FD;
    padding: 4px;
    outline: none;
}

QComboBox#ManageLibComboBox QAbstractItemView::item {
    padding: 6px 12px;
    border-radius: 4px;
}

QComboBox#ManageLibComboBox QAbstractItemView::item:hover {
    background-color: rgba(255, 255, 255, 0.06);
}

QComboBox#ManageLibComboBox QAbstractItemView::item:selected,
QComboBox#ManageLibComboBox QAbstractItemView::item:selected:hover {
    background-color: rgba(59, 130, 246, 0.20);
    color: #93C5FD;
}

QComboBox#ManageLibComboBox:disabled {
    background-color: rgba(255, 255, 255, 0.03);
    border-color: rgba(255, 255, 255, 0.05);
    color: rgba(226, 232, 240, 0.35);
}

QComboBox#ManageLibComboBox:disabled::down-arrow {
    opacity: 0.3;
}

/* ═══════════════════════════════════════════════════════════════
   ServerBrowserDialog — 服务器目录浏览
   ═══════════════════════════════════════════════════════════════ */

QTreeWidget#ServerBrowserTree {
    background-color: rgba(15, 23, 42, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 6px;
    outline: none;
    color: #CBD5E1;
    font-size: 13px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

QTreeWidget#ServerBrowserTree::item {
    padding: 5px 8px 5px 2px;
    margin: 1px 0;
    background-color: transparent;
}

QTreeWidget#ServerBrowserTree::item:hover {
    background-color: transparent;
}

QTreeWidget#ServerBrowserTree::item:selected {
    background-color: transparent;
    color: #93C5FD;
}

QTreeWidget#ServerBrowserTree::branch {
    background: transparent;
    border-image: none;
    image: none;
}

QTreeWidget#ServerBrowserTree::branch:has-children:!has-siblings:closed,
QTreeWidget#ServerBrowserTree::branch:closed:has-children:has-siblings {
    border-image: none;
    image: url(:/svg/dark/tree-closed.svg);
}

QTreeWidget#ServerBrowserTree::branch:open:has-children:!has-siblings,
QTreeWidget#ServerBrowserTree::branch:open:has-children:has-siblings {
    border-image: none;
    image: url(:/svg/dark/tree-open.svg);
}

/* ═══════════════════════════════════════════════════════════════
   PathRowWidget — 路径行
   ═══════════════════════════════════════════════════════════════ */

QLabel#ManageLibPathLabel {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    padding: 5px 10px;
    color: rgba(255, 255, 255, 0.7);
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    min-height: 20px;
}

QLabel#ManageLibPathLabel[empty="true"] {
    border-style: dashed;
    color: rgba(255, 255, 255, 0.3);
    font-style: italic;
}

QPushButton#ManageLibPathBrowseBtn {
    background: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(59, 130, 246, 0.25);
    border-radius: 6px;
    qproperty-icon: url(:/svg/dark/plus.svg);
    qproperty-iconSize: 14px;
}

QPushButton#ManageLibPathBrowseBtn:hover {
    background: rgba(59, 130, 246, 0.22);
    border-color: rgba(59, 130, 246, 0.4);
}

QPushButton#ManageLibPathRemoveBtn {
    background: rgba(239, 68, 68, 0.10);
    border: 1px solid rgba(239, 68, 68, 0.20);
    border-radius: 6px;
    qproperty-icon: url(:/svg/dark/minus.svg);
    qproperty-iconSize: 14px;
}

QPushButton#ManageLibPathRemoveBtn:hover {
    background: rgba(239, 68, 68, 0.20);
    border-color: rgba(239, 68, 68, 0.35);
}

/* ═══════════════════════════════════════════════════════════════
   扫描进度条
   ═══════════════════════════════════════════════════════════════ */
QProgressBar#ManageLibScanProgress {
    min-height: 2px;
    max-height: 2px;
    background-color: rgba(255, 255, 255, 0.12);
    border: 1px solid transparent;
    border-radius: 1px;
}

QProgressBar#ManageLibScanProgress::chunk {
    background-color: #3B82F6;
    border-radius: 1px;
}

/* 取消扫描按钮 */
QPushButton#ManageLibCancelScanBtn {
    background-color: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 10px;
    qproperty-icon: url(":/svg/dark/close.svg");
    qproperty-iconSize: 10px 10px;
}

QPushButton#ManageLibCancelScanBtn:hover {
    background-color: rgba(239, 68, 68, 0.30);
    border-color: rgba(239, 68, 68, 0.5);
}

QPushButton#ManageLibCancelScanBtn:pressed {
    background-color: rgba(239, 68, 68, 0.45);
}

/* ═══════════════════════════════════════════════════════════════
   ModernTagInput — 标签输入控件（暗色主题）
   ═══════════════════════════════════════════════════════════════ */

/* 整体容器框：模拟 lineEdit 外观 */
QFrame#TagInputContainer {
    background-color: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 8px;
}

QFrame#TagInputContainer:focus-within {
    border-color: rgba(59, 130, 246, 0.50);
}

/* 内嵌无边框输入框 */
QLineEdit#TagInputInlineEdit {
    background: transparent;
    border: none;
    color: #E2E8F0;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 0;
    selection-background-color: rgba(59, 130, 246, 0.40);
    selection-color: #FFFFFF;
}

/* 选中标签药片（可点击 ✕ 移除） */
QPushButton#TagChipInline {
    background-color: rgba(59, 130, 246, 0.18);
    border: 1px solid rgba(59, 130, 246, 0.32);
    border-radius: 10px;
    color: #93C5FD;
    font-size: 11px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 0px 8px;
}

QPushButton#TagChipInline:hover {
    background-color: rgba(239, 68, 68, 0.22);
    border-color: rgba(239, 68, 68, 0.45);
    color: #FCA5A5;
}

QPushButton#TagChipInline:pressed {
    background-color: rgba(239, 68, 68, 0.35);
}

/* 折叠汇总药片（+N） */
QPushButton#TagChipSummary {
    background-color: rgba(148, 163, 184, 0.12);
    border: 1px solid rgba(148, 163, 184, 0.22);
    border-radius: 10px;
    color: #94A3B8;
    font-size: 11px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 0px 7px;
}

QPushButton#TagChipSummary:hover {
    background-color: rgba(148, 163, 184, 0.22);
    border-color: rgba(148, 163, 184, 0.40);
    color: #CBD5E1;
}

/* 清除全部按钮 */
QToolButton#TagInputClearBtn {
    background: transparent;
    border: none;
    qproperty-icon: url(:/svg/dark/close.svg);
    qproperty-iconSize: 10px 10px;
    border-radius: 5px;
}

QToolButton#TagInputClearBtn:hover {
    background-color: rgba(239, 68, 68, 0.20);
}

QToolButton#TagInputClearBtn:pressed {
    background-color: rgba(239, 68, 68, 0.35);
}

/* 展开预设菜单按钮 */
QToolButton#TagInputMoreBtn {
    background: transparent;
    border: none;
    qproperty-icon: url(:/svg/dark/chevron-down.svg);
    qproperty-iconSize: 13px 13px;
    border-radius: 6px;
}

QToolButton#TagInputMoreBtn:hover {
    background-color: rgba(59, 130, 246, 0.18);
}

QToolButton#TagInputMoreBtn:pressed {
    background-color: rgba(59, 130, 246, 0.30);
}

/* ── 预设弹出面板 ── */
QFrame#TagPresetPopup {
    background-color: #1A2438;
    border: 1px solid rgba(255, 255, 255, 0.11);
    border-radius: 10px;
}

/* 弹出面板内搜索框：小巧精致 */
QLineEdit#TagPresetSearchEdit {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 6px;
    color: #CBD5E1;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 3px 8px;
    min-height: 0;
    max-height: 26px;
    selection-background-color: rgba(59, 130, 246, 0.40);
    selection-color: #FFFFFF;
}

QLineEdit#TagPresetSearchEdit:focus {
    border-color: rgba(59, 130, 246, 0.50);
    background-color: rgba(255, 255, 255, 0.09);
}

/* 弹出面板内复选框 */
QFrame#TagPresetOptionRow {
    background-color: transparent;
    border-radius: 5px;
}

QFrame#TagPresetOptionRow:hover {
    background-color: rgba(255, 255, 255, 0.06);
}

QFrame#TagPresetOptionRow:hover QCheckBox#TagPresetCheckbox {
    color: #E2E8F0;
}

QFrame#TagPresetOptionRow:hover QCheckBox#TagPresetCheckbox::indicator {
    border-color: rgba(59, 130, 246, 0.55);
}

QCheckBox#TagPresetCheckbox {
    background-color: transparent;
    border: none;
    color: #CBD5E1;
    font-size: 13px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    spacing: 8px;
    padding: 3px 6px;
    border-radius: 5px;
}

QCheckBox#TagPresetCheckbox:hover {
    background-color: rgba(255, 255, 255, 0.06);
    color: #E2E8F0;
}

QCheckBox#TagPresetCheckbox::indicator {
    width: 15px;
    height: 15px;
    border-radius: 4px;
    border: 1px solid rgba(255, 255, 255, 0.20);
    background-color: rgba(255, 255, 255, 0.05);
}

QCheckBox#TagPresetCheckbox::indicator:hover {
    border-color: rgba(59, 130, 246, 0.55);
}

QCheckBox#TagPresetCheckbox::indicator:checked {
    background-color: #3B82F6;
    border-color: #3B82F6;
    image: url(:/svg/dark/check.svg);
}

/* 弹出面板内滚动区 */
QScrollArea#TagPresetScrollArea {
    background: transparent;
    border: none;
}

QScrollArea#TagPresetScrollArea > QWidget > QWidget {
    background: transparent;
}

/* 弹出面板滚动条：贴边无间隙 */
QScrollArea#TagPresetScrollArea QScrollBar:vertical {
    background: transparent;
    width: 5px;
    margin: 0;
    border: none;
    border-radius: 2px;
}

QScrollArea#TagPresetScrollArea QScrollBar::handle:vertical {
    background: rgba(255, 255, 255, 0.18);
    border-radius: 2px;
    min-height: 24px;
}

QScrollArea#TagPresetScrollArea QScrollBar::handle:vertical:hover {
    background: rgba(255, 255, 255, 0.32);
}

QScrollArea#TagPresetScrollArea QScrollBar::add-line:vertical,
QScrollArea#TagPresetScrollArea QScrollBar::sub-line:vertical {
    height: 0;
    background: none;
}

QScrollArea#TagPresetScrollArea QScrollBar::add-page:vertical,
QScrollArea#TagPresetScrollArea QScrollBar::sub-page:vertical {
    background: none;
}

/* =====================================================================
   播放列表 & 合集管理 (PageCollections) - 暗黑模式
   ===================================================================== */

/* ── CollectionCard 操作按钮 ── */
QPushButton#CollCardRenameBtn,
QPushButton#CollCardDeleteBtn {
    background: transparent;
    border: none;
    border-radius: 6px;
    qproperty-iconSize: 14px 14px;
}

QPushButton#CollCardRenameBtn {
    qproperty-icon: url(":/svg/dark/edit.svg");
}
QPushButton#CollCardRenameBtn:hover {
    background-color: rgba(59, 130, 246, 0.25);
}
QPushButton#CollCardRenameBtn:pressed {
    background-color: rgba(59, 130, 246, 0.4);
}

QPushButton#CollCardDeleteBtn {
    qproperty-icon: url(":/svg/dark/delete.svg");
}
QPushButton#CollCardDeleteBtn:hover {
    background-color: rgba(239, 68, 68, 0.25);
}
QPushButton#CollCardDeleteBtn:pressed {
    background-color: rgba(239, 68, 68, 0.4);
}
QPushButton#CollCardDeleteBtn:disabled {
    background: transparent;
    opacity: 0.35;
}

/* ── 管理页 Tab 按钮 ── */
QPushButton#ManageTabBtn {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.10);
    border-radius: 8px;
    color: #94A3B8;
    font-size: 13px;
    font-weight: 500;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 4px 16px;
}

QPushButton#ManageTabBtn:hover {
    background-color: rgba(255, 255, 255, 0.10);
    color: #CBD5E1;
}

QPushButton#ManageTabBtn:checked {
    background-color: rgba(59, 130, 246, 0.20);
    border-color: rgba(59, 130, 246, 0.4);
    color: #93C5FD;
}

QPushButton#ManageTabBtn:checked:hover {
    background-color: rgba(59, 130, 246, 0.28);
}

/* =====================================================================
   P7 — 用户管理 / 定时任务 / 系统日志 (Dark Mode)
   ===================================================================== */

QFrame#ManageUserCard {
    background-color: rgba(30, 41, 59, 0.5);
    border: 1px solid rgba(71, 85, 105, 0.4);
    border-radius: 12px;
}

QFrame#ManageUserCard:hover {
    background-color: rgba(30, 41, 59, 0.65);
    border-color: rgba(96, 165, 250, 0.5);
}

/* 用户头像圆形 */
QLabel#ManageUserAvatar {
    background-color: rgba(59, 130, 246, 0.2);
    border: 1px solid rgba(59, 130, 246, 0.35);
    border-radius: 24px;
    color: #93C5FD;
    font-size: 18px;
    font-weight: 700;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

/* 管理员徽章 */
QLabel#ManageUserBadgeAdmin {
    background-color: rgba(59, 130, 246, 0.18);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 4px;
    color: #93C5FD;
    font-size: 11px;
    font-weight: 600;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 1px 8px;
}

/* 禁用徽章 */
QLabel#ManageUserBadgeDisabled {
    background-color: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 4px;
    color: #FCA5A5;
    font-size: 11px;
    font-weight: 600;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    padding: 1px 8px;
}

/* 任务详情按钮 */
QPushButton#ManageTaskDetailsBtn {
    background-color: rgba(59, 130, 246, 0.10);
    border: 1px solid rgba(59, 130, 246, 0.24);
    border-radius: 8px;
    qproperty-icon: url(":/svg/dark/edit.svg");
    qproperty-iconSize: 14px 14px;
}

QPushButton#ManageTaskDetailsBtn:hover {
    background-color: rgba(59, 130, 246, 0.18);
    border-color: rgba(59, 130, 246, 0.38);
}

QPushButton#ManageTaskDetailsBtn:pressed {
    background-color: rgba(59, 130, 246, 0.26);
}

/* 任务运行按钮 */
QPushButton#ManageTaskRunBtn {
    background-color: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
    qproperty-icon: url(":/svg/dark/task-run.svg");
    qproperty-iconSize: 14px 14px;
}

QPushButton#ManageTaskRunBtn:hover {
    background-color: rgba(34, 197, 94, 0.25);
    border-color: rgba(34, 197, 94, 0.5);
}

QPushButton#ManageTaskRunBtn:pressed {
    background-color: rgba(34, 197, 94, 0.35);
}

/* 任务停止按钮 */
QPushButton#ManageTaskStopBtn {
    background-color: rgba(239, 68, 68, 0.15);
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 8px;
    qproperty-icon: url(":/svg/dark/task-stop.svg");
    qproperty-iconSize: 14px 14px;
}

QPushButton#ManageTaskStopBtn:hover {
    background-color: rgba(239, 68, 68, 0.25);
    border-color: rgba(239, 68, 68, 0.5);
}

QPushButton#ManageTaskStopBtn:pressed {
    background-color: rgba(239, 68, 68, 0.35);
}

/* 任务进度条 */
QProgressBar#ManageTaskProgress {
    min-height: 4px;
    max-height: 4px;
    background-color: rgba(255, 255, 255, 0.1);
    border: none;
    border-radius: 2px;
}

QProgressBar#ManageTaskProgress::chunk {
    background-color: #3B82F6;
    border-radius: 2px;
}

QLabel#ManageLogSelectedName {
    color: #F8FAFC;
    font-size: 14px;
    font-weight: 600;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

QLabel#ManageLogSelectedMeta {
    color: #94A3B8;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

QFrame#ManageLogListCard {
    background-color: transparent;
    border: none;
}

QFrame#ManageLogViewerCard {
    background-color: transparent;
    border: none;
}

QFrame#ManageLogDivider {
    background-color: rgba(71, 85, 105, 0.42);
    border: none;
}

/* 日志文件列表 */
QListWidget#ManageLogFileList {
    background-color: transparent;
    border: none;
    color: #E2E8F0;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
    outline: none;
    padding: 0px;
}

QListWidget#ManageLogFileList::item {
    margin: 0px;
    padding: 0px;
    border: none;
}

QListWidget#ManageLogFileList::item:selected {
    background-color: transparent;
    color: #E2E8F0;
}

QListWidget#ManageLogFileList::item:hover:!selected {
    background-color: transparent;
}

/* 日志内容查看器 */
QPlainTextEdit#ManageLogViewer {
    background-color: transparent;
    border: none;
    color: #CBD5E1;
    font-size: 12px;
    font-family: "Consolas", "Courier New", monospace;
    padding: 0px;
    selection-background-color: rgba(59, 130, 246, 0.3);
}

/* =================================================================
   P7.2 — 用户管理增强样式 (暗色)
   ================================================================= */

/* 用户删除按钮 */
#ManageUserDeleteBtn {
    background-color: transparent;
    border: 1px solid rgba(239, 68, 68, 0.3);
    border-radius: 6px;
    qproperty-icon: url(:/svg/dark/delete.svg);
    qproperty-iconSize: 16px 16px;
}
#ManageUserDeleteBtn:hover {
    background-color: rgba(239, 68, 68, 0.15);
    border-color: rgba(239, 68, 68, 0.5);
}
#ManageUserDeleteBtn:pressed {
    background-color: rgba(239, 68, 68, 0.25);
}
#ManageUserDeleteBtn:disabled {
    opacity: 0.3;
    border-color: rgba(100, 116, 139, 0.2);
}

/* UserEditDialog 导航条 */
QFrame#UserEditNavCard {
    background-color: rgba(30, 41, 59, 0.62);
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 12px;
}

QTabBar#UserEditTabBar {
    background: transparent;
}

QTabBar#UserEditTabBar::tab {
    background-color: transparent;
    color: #94A3B8;
    padding: 8px 14px;
    margin-right: 6px;
    border: 1px solid transparent;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 500;
    min-width: 0px;
}

QTabBar#UserEditTabBar::tab:selected {
    background-color: rgba(15, 23, 42, 0.72);
    color: #E2E8F0;
    border-color: rgba(148, 163, 184, 0.16);
}

QTabBar#UserEditTabBar::tab:hover:!selected {
    color: #CBD5E1;
    background-color: rgba(255, 255, 255, 0.05);
}

QFrame#UserEditSectionCard {
    background-color: rgba(30, 41, 59, 0.58);
    border: 1px solid rgba(148, 163, 184, 0.10);
    border-radius: 12px;
}

QLabel#UserEditSectionTitle {
    color: #F1F5F9;
    font-size: 14px;
    font-weight: 700;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

QWidget#UserEditSwitchRow {
    background-color: rgba(15, 23, 42, 0.42);
    border: 1px solid rgba(148, 163, 184, 0.10);
    border-radius: 10px;
}

QWidget#UserEditSwitchRow:hover {
    border-color: rgba(96, 165, 250, 0.26);
}

QWidget#UserEditFolderListContainer {
    background-color: rgba(15, 23, 42, 0.4);
    border: 1px solid rgba(148, 163, 184, 0.10);
    border-radius: 10px;
}

QFrame#UserEditFooterBar {
    background-color: rgba(15, 23, 42, 0.78);
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 12px;
}

/* UserEdit 滚动区 */
#UserEditScrollArea {
    background-color: transparent;
    border: none;
}
#UserEditScrollArea > QWidget > QWidget {
    background-color: transparent;
}

/* UserEdit 文本输入框 */
#UserEditLineEdit {
    background-color: rgba(30, 41, 59, 0.6);
    border: 1px solid rgba(148, 163, 184, 0.2);
    border-radius: 8px;
    color: #E2E8F0;
    padding: 9px 12px;
    font-size: 13px;
}
#UserEditLineEdit:focus {
    border-color: #3B82F6;
}

/* 保存按钮 */
#ManageSaveBtn {
    background-color: rgba(34, 197, 94, 0.16);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
    qproperty-icon: url(":/svg/dark/check.svg");
    qproperty-iconSize: 16px 16px;
}
#ManageSaveBtn:hover {
    background-color: rgba(34, 197, 94, 0.24);
    border-color: rgba(34, 197, 94, 0.45);
}
#ManageSaveBtn:pressed {
    background-color: rgba(34, 197, 94, 0.32);
}
#ManageSaveBtn:disabled {
    background-color: rgba(51, 65, 85, 0.3);
    border-color: rgba(71, 85, 105, 0.2);
}

/* =====================================================================
   TaskEditDialog 样式
   ===================================================================== */
QLabel#TaskSummaryValue {
    color: #F8FAFC;
    font-size: 24px;
    font-weight: 700;
}
QLabel#TaskSummaryCaption {
    color: rgba(148, 163, 184, 0.92);
    font-size: 12px;
    font-weight: 600;
}
QLabel#TaskMetaBadge {
    background-color: rgba(59, 130, 246, 0.12);
    border: 1px solid rgba(59, 130, 246, 0.22);
    border-radius: 10px;
    color: #BFDBFE;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
}
QLabel#TaskMutedBadge {
    background-color: rgba(51, 65, 85, 0.72);
    border: 1px solid rgba(148, 163, 184, 0.16);
    border-radius: 10px;
    color: rgba(226, 232, 240, 0.88);
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
}
QWidget#TaskEditTriggerRow {
    background-color: rgba(15, 23, 42, 0.55);
    border: 1px solid rgba(148, 163, 184, 0.12);
    border-radius: 10px;
}
QLabel#TaskTriggerMetaLabel {
    color: rgba(148, 163, 184, 0.88);
    font-size: 12px;
}
QLabel#TaskReadOnlyBadge {
    background-color: rgba(245, 158, 11, 0.12);
    border: 1px solid rgba(245, 158, 11, 0.22);
    border-radius: 10px;
    color: #FCD34D;
    padding: 3px 10px;
    font-size: 11px;
    font-weight: 600;
}
QWidget#TaskEditAddForm {
    background-color: rgba(30, 41, 59, 0.5);
    border: 1px solid rgba(59, 130, 246, 0.25);
    border-radius: 8px;
}
QPushButton#TaskEditAddTriggerBtn {
    background-color: rgba(59, 130, 246, 0.15);
    border: 1px solid rgba(59, 130, 246, 0.3);
    border-radius: 6px;
    color: #93C5FD;
    padding: 6px 14px;
    font-size: 12px;
    font-weight: 600;
}
QPushButton#TaskEditAddTriggerBtn:hover {
    background-color: rgba(59, 130, 246, 0.25);
}

