    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

/* ---- 活动日志列表 ---- */
QListView#ActivityLogList {
    background: transparent;
    border: none;
    outline: none;
}

QListView#ActivityLogList::item {
    background: transparent;
    border: none;
    padding: 0;
}

/* ---- 活动日志主题色（QSS → Delegate） ---- */
#activity-log-theme {
    qproperty-cardBg: rgba(51, 65, 85, 102);
    qproperty-borderColor: rgba(71, 85, 105, 77);
    qproperty-nameColor: #F1F5F9;
    qproperty-overviewColor: #94A3B8;
    qproperty-timeColor: #64748B;
}

