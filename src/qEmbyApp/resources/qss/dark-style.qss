}

QLabel#NowPlayingTitle {
    color: #E2E8F0;
    font-size: 14px;
    font-weight: 600;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

QLabel#NowPlayingSubtitle {
    color: #94A3B8;
    font-size: 12px;
    font-family: "Segoe UI", "Microsoft YaHei", sans-serif;
}

QLabel#NowPlayingProgress {
    color: #CBD5E1;
